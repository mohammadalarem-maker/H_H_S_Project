<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="لوحة الإدارة - إضافة منتج"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/etProdName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="اسم المنتج (مثال: شاحن سريع 20 واط)"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etProdDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="وصف المنتج ومواصفاته"
            android:inputType="textMultiLine"
            android:lines="3"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etProdPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="السعر (بالريال اليمني)"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etProdCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="القسم (اكتب بدقة: هواتف / إكسسوارات / مستحضرات تجميل)"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etProdStock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="الكمية المتوفرة بالمخزن"
            android:inputType="number"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnAddProduct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="حفظ المنتج ورفعه للمتجر سحابياً"
            android:textSize="16sp"/>

    </LinearLayout>
</ScrollView>
