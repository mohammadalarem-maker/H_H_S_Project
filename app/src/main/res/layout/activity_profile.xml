<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="الملف الشخصي"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <!-- أيقونة مستخدم افتراضية -->
    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@mipmap/ic_launcher_round"
        android:layout_marginBottom="16dp"
        android:contentDescription="صورة الحساب"/>

    <!-- عرض البريد الإلكتروني للزبون -->
    <TextView
        android:id="@+id/tvProfileEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="بريد المستخدم ستظهر هنا"
        android:textSize="18sp"
        android:textColor="#333333"
        android:layout_marginBottom="40dp"/>

    <!-- زر لوحة الإدارة (سيكون مخفياً بشكل افتراضي ويظهر لك فقط) -->
    <Button
        android:id="@+id/btnAdminPanel"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="الدخول إلى لوحة الإدارة 🛠️"
        android:textSize="16sp"
        android:backgroundTint="#4CAF50"
        android:layout_marginBottom="16dp"
        android:visibility="gone"/>

    <!-- زر تسجيل الخروج -->
    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="تسجيل الخروج من التطبيق"
        android:textSize="16sp"
        android:backgroundTint="#D32F2F"/>

</LinearLayout>
