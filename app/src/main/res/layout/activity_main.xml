<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- شريط علوي ترحيبي مع زر السلة والملف الشخصي -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">
        
        <Button
            android:id="@+id/btnOpenCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="السلة 🛒"
            android:backgroundTint="#E91E63"
            android:layout_marginRight="4dp"/>

        <Button
            android:id="@+id/btnOpenProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="حسابي 👤"
            android:backgroundTint="#607D8B"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="متجر الحسام"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تصفح الأقسام:"
        android:textSize="16sp"
        android:layout_gravity="right"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnPhones"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="قسم الهواتف الذكية"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnAccessories"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="قسم الإكسسوارات"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnCosmetics"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="قسم مستحضرات التجميل"/>

</LinearLayout>
